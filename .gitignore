# =============================================================================
# Virtual environments
# =============================================================================
venv/
conda_envs/
.venv/
env/

# =============================================================================
# Python cache & build artefacts
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Jupyter / IPython
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Evaluation result CSVs
# (large generated files — reproducible by re-running eval scripts)
# =============================================================================
results/baseline/*.csv
results/mad_graph/*.csv
results/mad_graph_pride/*.csv
results/mad_graph_selective/output/*.csv
results/mad_graph_selective/*.csv

# Keep deprecated folders out of git too
results/mad_graph_selective/deprecated/
results/mad_graph/analysis/

# =============================================================================
# PriDe output (generated — not source)
# =============================================================================
pride/results/

# =============================================================================
# Slurm / HPC logs
# =============================================================================
slurm_output/
*.out
*.err

# =============================================================================
# HuggingFace model cache (can be huge)
# =============================================================================
.cache/
cache/

# =============================================================================
# OS / editor artefacts
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# =============================================================================
# Secrets / credentials
# =============================================================================
.env
*.key
*.pem
secrets.py
